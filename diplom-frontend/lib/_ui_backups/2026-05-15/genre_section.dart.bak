// ─── Публичный виджет секции жанров ─────────────────────────────────────────

class GenreSection extends StatelessWidget {
  const GenreSection({super.key});

  @override
  Widget build(BuildContext context) {
    return GridView.builder(
      shrinkWrap: true,
      physics: const NeverScrollableScrollPhysics(),
      padding: const EdgeInsets.symmetric(horizontal: 20),
      gridDelegate: const SliverGridDelegateWithFixedCrossAxisCount(
        crossAxisCount: 2,
        mainAxisSpacing: 10,
        crossAxisSpacing: 10,
        childAspectRatio: 2.4,
      ),
      itemCount: _genres.length,
      itemBuilder: (ctx, i) => _GenreCard(data: _genres[i]),
    );
  }
}

// ─── Карточка жанра с загрузкой обложки ─────────────────────────────────────

class _GenreCard extends StatefulWidget {
  final _GenreData data;
  const _GenreCard({required this.data});

  @override
  State<_GenreCard> createState() => _GenreCardState();
}

class _GenreCardState extends State<_GenreCard> {
  String? _coverUrl;

  @override
  void initState() {
    super.initState();
    _loadCover();
  }

  Future<void> _loadCover() async {
    try {
      final tracks =
          await ApiService().getCharts(genre: widget.data.name, limit: 1);
      if (!mounted || tracks.isEmpty) return;
      final url = tracks.first['cover_url']?.toString() ??
          tracks.first['image']?.toString() ??
          tracks.first['album_cover']?.toString();
      if (url != null && url.isNotEmpty) {
        setState(() => _coverUrl = url);
      }
    } catch (_) {}
  }

  @override
  Widget build(BuildContext context) {
    final d = widget.data;
    return GestureDetector(
      onTap: () => Navigator.push(
        context,
        MaterialPageRoute(
          builder: (_) => GenreTracksScreen(
            genre: d.name,
            emoji: d.emoji,
            gradient: d.gradient,
          ),
        ),
      ),
      child: ClipRRect(
        borderRadius: BorderRadius.circular(18),
        child: Stack(
          fit: StackFit.expand,
          children: [
            // Фоновая обложка (если загружена)
            if (_coverUrl != null)
              CachedNetworkImage(
                imageUrl: _coverUrl!,
                fit: BoxFit.cover,
                errorWidget: (_, __, ___) => const SizedBox.shrink(),
              ),

            // Градиентный оверлей
            Container(
              decoration: BoxDecoration(
                gradient: LinearGradient(
                  colors: [
                    d.gradient.colors.first.withOpacity(
                        _coverUrl != null ? 0.72 : 1.0),
                    d.gradient.colors.last.withOpacity(
                        _coverUrl != null ? 0.65 : 1.0),
                  ],
                  begin: d.gradient.begin,
                  end: d.gradient.end,
                ),
              ),
            ),

            // Emoji + название
            Padding(
              padding: const EdgeInsets.symmetric(horizontal: 14),
              child: Row(
                children: [
                  Text(d.emoji,
                      style: const TextStyle(fontSize: 22)),
                  const SizedBox(width: 8),
                  Flexible(
                    child: Text(
                      d.name,
                      style: GoogleFonts.outfit(
                        fontSize: 15,
                        fontWeight: FontWeight.w700,
                        color: Colors.white,
                      ),
                      overflow: TextOverflow.ellipsis,
                    ),
                  ),
                ],
              ),
            ),
          ],
        ),
      ),
    );
  }
}