APP_ENV=production

# Railway usually provides these when you attach PostgreSQL and Redis.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB
REDIS_URL=redis://default:PASSWORD@HOST:PORT

SECRET_KEY=replace_with_a_long_random_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Public frontend URL after Firebase/Vercel deploy.
FRONTEND_URL=https://your-frontend.web.app
CORS_ORIGINS=https://your-frontend.web.app

OPENWEATHER_API_KEY=replace_me
YOUTUBE_API_KEY=replace_me

SPOTIFY_CLIENT_ID=replace_me
SPOTIFY_CLIENT_SECRET=replace_me
SPOTIFY_REDIRECT_URI=https://your-backend.up.railway.app/auth/spotify/callback

FIREBASE_DATABASE_URL=https://your-project-default-rtdb.region.firebasedatabase.app
# Paste the whole service account JSON as one Railway variable.
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

GOOGLE_CLIENT_ID=replace_me

# Optional email features.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
