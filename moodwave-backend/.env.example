# OpenWeatherMap
OPENWEATHER_API_KEY=

# Firebase
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
FIREBASE_DATABASE_URL=

# Mail (Gmail SMTP)
MAIL_USERNAME=
MAIL_PASSWORD=
