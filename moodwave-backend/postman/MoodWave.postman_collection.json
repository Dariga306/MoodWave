          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.environment.set(\"reset_token\", pm.response.json().reset_token);",
                  "}"
