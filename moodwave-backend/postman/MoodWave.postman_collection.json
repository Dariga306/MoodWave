  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "description": "Creates a new user account and sends an email verification code.",
            "url": "{{base_url}}/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"username\": \"testuser\",\n  \"password\": \"password123\",\n  \"first_name\": \"Test\",\n  \"last_name\": \"User\",\n  \"birth_date\": \"2000-01-01\",\n  \"city\": \"Astana\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "description": "Authenticates a user and stores returned tokens in the active Postman environment.",
            "url": "{{base_url}}/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.environment.set(\"access_token\", pm.response.json().access_token);",
                  "pm.environment.set(\"refresh_token\", pm.response.json().refresh_token);",
                  "pm.environment.set(\"user_id\", pm.response.json().user.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "description": "Uses the saved refresh token to request a fresh access token pair.",
            "url": "{{base_url}}/auth/refresh",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "POST",
            "description": "Confirms the six-digit verification code that was sent after registration.",
            "url": "{{base_url}}/auth/verify-email",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"code\": \"{{verification_code}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Resend Verification",
          "request": {
