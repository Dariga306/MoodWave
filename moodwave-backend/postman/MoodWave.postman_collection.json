              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "description": "Starts the password reset flow by emailing a reset code.",
            "url": "{{base_url}}/auth/forgot-password",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Verify Reset Code",
          "request": {
            "method": "POST",
            "description": "Validates the reset code and returns a reset token.",
            "url": "{{base_url}}/auth/verify-reset-code",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"code\": \"{{reset_code}}\"\n}",
              "options": {
                "raw": {
